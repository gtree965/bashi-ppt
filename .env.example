# Bashi PPT v0.1.0 configuration
# Copy this file to .env. Never commit or share the populated .env file.

# === LM Studio (default, local) ===
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model

# === Ollama (local alternative) ===
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3:8b

# === OpenRouter (cloud example) ===
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_MODEL=your-model-id

# === Other OpenAI-compatible cloud service ===
# Choose a provider label accepted by the application, then set the custom URL.
# For providers not represented in the UI, editing .env is the reliable path.
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://your-provider.example/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=provider-model-id

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384
LLM_TIMEOUT=1200

# Optional Pixabay image search
PIXABAY_API_KEY=

# Flask
FLASK_PORT=5100
FLASK_DEBUG=false

# SSL Verification (set to false to bypass SSL verification errors behind certain VPNs/proxies)
VERIFY_SSL=true
