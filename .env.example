# Bashi PPT (巴适PPT) Configuration
# Copy this file to .env and modify as needed

# === LM Studio (default, local) ===
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.5-4b

# === OpenRouter (cloud alternative) ===
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# === Mistral (cloud alternative) ===
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_API_KEY=your-mistral-key
# LLM_MODEL=mistral-large-latest

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384
LLM_TIMEOUT=360

# Flask
FLASK_PORT=5100
FLASK_DEBUG=true

# SSL Verification (set to false to bypass SSL verification errors behind certain VPNs/proxies)
VERIFY_SSL=true
