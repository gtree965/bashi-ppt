# Bashi PPT v0.1.0 configuration
# Copy this file to .env. Never commit or share the populated .env file.

# === Active AI model settings (edited by the app) ===
# Default is local LM Studio. Use the gear icon in the app to switch providers.
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model

# === LM Studio (local example) ===
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=local-model

# === Ollama (local alternative) ===
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3:8b

# === OpenRouter (cloud example) ===
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_MODEL=openrouter/free

# === SiliconFlow / 硅基流动 (cloud example) ===
# LLM_PROVIDER=siliconflow
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_MODEL=Qwen/Qwen3.6-35B-A3B

# === Alibaba Cloud Bailian / 阿里云百炼 DashScope (cloud example) ===
# LLM_PROVIDER=dashscope
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-key
# LLM_MODEL=qwen3.7-plus

# === Other OpenAI-compatible cloud service ===
# Use custom when the service is not listed in the settings UI.
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://your-provider.example/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=provider-model-id

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384
LLM_TIMEOUT=1200

# Optional Pixabay image search
PIXABAY_API_KEY=

# Flask
FLASK_PORT=5100
FLASK_DEBUG=false

# SSL Verification (set to false to bypass SSL verification errors behind certain VPNs/proxies)
VERIFY_SSL=true
